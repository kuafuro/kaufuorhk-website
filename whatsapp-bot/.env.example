# ==========================================================================
#  Kuafuor WhatsApp bot — 環境變數樣本
#  真正嘅 value 唔好寫喺呢度 / 唔好 commit 落 git。
#  部署嗰陣喺 Railway → Variables 度逐個填。
# ==========================================================================

# ---- WhatsApp Cloud API（喺 Meta「API Setup」攞 / 自己定）----
WHATSAPP_TOKEN=                 # Meta 永久 System User access token（唔好放落 chat / git）
WHATSAPP_PHONE_NUMBER_ID=       # Meta API Setup 見到嘅 Phone Number ID
WHATSAPP_VERIFY_TOKEN=          # 你自己改一串密碼字（webhook 驗證 + 手動觸發用）
WHATSAPP_TEMPLATE_NAME=class_reminder   # WhatsApp Manager 入面建立嘅 template 名
WHATSAPP_TEMPLATE_LANG=zh_HK            # template 語言（繁中香港）

# ---- Supabase ----
SUPABASE_URL=https://ikzoxrvnpsseyjviawti.supabase.co
SUPABASE_SERVICE_ROLE_KEY=      # Supabase → Project Settings → API → service_role key（機密！）

# ---- App 設定 ----
PORT=3000
TIMEZONE=Asia/Hong_Kong
REMINDER_HOURS_BEFORE=24,2      # 堂前幾多個鐘各提一次（逗號分隔）
SCAN_WINDOW_MINUTES=20          # 每次掃描嘅前後容忍範圍（分鐘）
